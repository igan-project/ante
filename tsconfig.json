{
  "compilerOptions": {
    "target": "ES2025",
    "lib": ["ES2025", "DOM"],
    "module": "NodeNext",
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noErrorTruncation": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["./src/declarations"],
    "paths": {
      "antejs": ["./src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist", "tests/bundle"]
}
