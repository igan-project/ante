{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "builtin": true,
    "es2022": true,
    "node": true,
    "browser": false
  },
  "plugins": ["typescript", "unicorn", "oxc", "jsdoc", "vitest"],
  "categories": {
    "correctness": "error",
    "restriction": "error",
    "suspicious": "warn"
  },
  "globals": {
    "console": "readonly",
    "module": "readonly",
    "exports": "writable",
    "require": "readonly",
    "define": "readonly",
    "Intl": "readonly",
    "Uint8Array": "readonly"
  },
  "overrides": [
    {
      "files": ["src/**"],
      "rules": {
        "typescript/no-namespace": "allow",
        "typescript/explicit-member-accessibility": "allow",
        "typescript/no-empty-object-type": "allow",
        "no-bitwise": "allow",
        "complexity": ["error", { "max": 25 }],
        "no-param-reassign": "allow",
        "default-case": "allow",
        "no-undefined": "allow"
      }
    },
    {
      "files": ["src/index.ts"],
      "rules": { "no-use-before-define": "allow" }
    },
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "env": {
        "vitest": true
      },
      "rules": { "vitest/require-test-timeout": "allow" }
    }
  ],
  "ignorePatterns": ["node_modules", "dist"]
}
