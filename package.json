{
  "name": "antejs",
  "version": "0.0.1",
  "description": "Ante is an immutable date / time / locale library alternative to Moment.js (or Day.js)",
  "keywords": [
    "ISO-8601",
    "antejs",
    "date",
    "dayjs",
    "immutable",
    "locale",
    "moment",
    "momentjs",
    "time"
  ],
  "license": "MIT",
  "author": "michaelhazan",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin/*": {
      "types": "./dist/plugin/*/index.d.ts",
      "import": "./dist/plugin/*/index.js",
      "require": "./dist/plugin/*/index.cjs"
    },
    "./declarations/*": {
      "types": "./dist/declarations/*.d.ts"
    }
  },
  "scripts": {
    "size": "size-limit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typescript": "tsc",
    "build": "tsdown"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "dayjs": "1.11.21",
    "knip": "6.15.0",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "pkg-pr-new": "0.0.75",
    "rollup-plugin-copy": "3.5.0",
    "size-limit": "12.1.0",
    "tsdown": "0.22.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "size-limit": [
    {
      "path": "./dist/index.js"
    },
    {
      "path": "./dist/index.cjs"
    }
  ],
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
