{
  "name": "antejs",
  "version": "0.0.1",
  "description": "Ante is an immutable date / time / locale library alternative to Moment.js (or Day.js)",
  "keywords": [
    "ISO-8601",
    "antejs",
    "date",
    "dayjs",
    "immutable",
    "locale",
    "moment",
    "momentjs",
    "time"
  ],
  "license": "MIT",
  "author": "michaelhazan",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "require": "./dist/plugin/index.cjs"
    },
    "./extension": {
      "types": "./dist/extension/index.d.ts",
      "import": "./dist/extension/index.js",
      "require": "./dist/extension/index.cjs"
    },
    "./plugin/*": {
      "types": "./dist/plugin/*/index.d.ts",
      "import": "./dist/plugin/*/index.js",
      "require": "./dist/plugin/*/index.cjs"
    },
    "./extension/*": {
      "types": "./dist/extension/*/index.d.ts",
      "import": "./dist/extension/*/index.js",
      "require": "./dist/extension/*/index.cjs"
    },
    "./declarations/*": {
      "types": "./dist/declarations/*.d.ts"
    }
  },
  "scripts": {
    "size": "size-limit",
    "test": "vitest run",
    "test:bundle": "vitest run --project=bundle",
    "test:raw": "vitest run --project=\"!bundle\"",
    "test:watch": "vitest watch",
    "spell": "cspell .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typescript": "tsc",
    "build": "tsdown",
    "check": "turbo run test spell lint format:check typescript build"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "cspell": "10.0.1",
    "dayjs": "1.11.21",
    "knip": "6.21.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "pkg-pr-new": "0.0.75",
    "rollup-plugin-copy": "3.5.0",
    "size-limit": "12.1.0",
    "tsdown": "0.22.3",
    "turbo": "2.10.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "size-limit": [
    {
      "path": "./dist/index.js"
    },
    {
      "path": "./dist/index.cjs"
    }
  ],
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
